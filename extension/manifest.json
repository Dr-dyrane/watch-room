{
  "manifest_version": 3,
  "name": "Private Watch Room Bridge",
  "version": "1.0.0",
  "description": "Minimal Netflix bridge for a private shared room.",
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": [
    "https://www.netflix.com/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "https://*.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.netflix.com/*",
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*",
        "https://*.vercel.app/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Private Watch Room Bridge",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  }
}
